{
  "expo": {
    "name": "حلم",
    "slug": "hilm-app",
    "version": "1.0.0",
    "scheme": "hilmapp",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#141110",
    "splash": {
      "backgroundColor": "#141110"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hilmlearning.app"
    },
    "android": {
      "package": "com.hilmlearning.app",
      "adaptiveIcon": {
        "backgroundColor": "#141110"
      }
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_YOUR_EAS_PROJECT_ID"
      }
    },
    "plugins": [
      "expo-font",
      "expo-video"
    ]
  }
}
